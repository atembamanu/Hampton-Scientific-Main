# Copy to ".env" at the repo root and fill in real values. Never commit .env.

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
DB_NAME=hampton_scientific

CORS_ORIGINS=http://localhost:3000
GOOGLE_API_KEY=
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=you@example.com
FRONTEND_URL=http://localhost:3000
SECRET_KEY=generate-a-long-random-string

# Postgres (Docker Compose + backend DATABASE_URL)
POSTGRES_DB=hampton_scientific
POSTGRES_USER=hs_user
POSTGRES_PASSWORD=changeme
# Docker Compose: host is the service name "postgres". Local Python: use localhost
DATABASE_URL=postgresql+psycopg2://hs_user:changeme@postgres:5432/hampton_scientific

# Frontend — inlined at build time (yarn build / Docker frontend image)
REACT_APP_BACKEND_URL=http://localhost:8001

# Mongo (optional legacy — only if you run a mongo service)
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_AUTH_SOURCE=admin
